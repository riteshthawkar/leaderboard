# Vision Leaderboard - Production Configuration
# ============================================================================
# Copy this file to .env and configure for your deployment

# ==============================================================================
# PATHS & DIRECTORIES
# ==============================================================================
# Root directories for benchmark datasets
DO_YOU_SEE_ME_ROOT=../Do-You-See-Me
MINDS_EYE_ROOT=../Mind-s-Eye

# ==============================================================================
# FLASK CONFIGURATION
# ==============================================================================
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5050

# ==============================================================================
# SECURITY & AUTHENTICATION
# ==============================================================================
# Flask secret key – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex-string

# API tokens (comma-separated) for admin/legacy access.
# Normal submissions use registered user tokens from /login.
API_TOKENS=

# Submission auth is required by default. Set true only for local UI testing.
DISABLE_SUBMISSION_AUTH=false
TEST_SUBMISSION_USER=local-test

# CORS origins (comma-separated) - specify allowed domains
CORS_ORIGINS=http://localhost:5050,http://localhost:5173,http://localhost:5174

# OAuth sign-in / sign-up (optional)
# Configure redirect URIs in each provider console as:
#   http://localhost:5050/api/auth/oauth/google/callback
#   http://localhost:5050/api/auth/oauth/microsoft/callback
# For production, set OAUTH_REDIRECT_BASE_URL=https://your-domain.example
OAUTH_REDIRECT_BASE_URL=http://localhost:5050
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# common supports personal Microsoft accounts and organizational tenants.
MICROSOFT_TENANT_ID=common

# ==============================================================================
# RATE LIMITING
# ==============================================================================
# Submissions per hour per IP address
SUBMISSIONS_PER_HOUR=10

# Storage for rate limiting (memory:// for single server, redis:// for distributed)
LIMITER_STORAGE_URI=memory://

# ==============================================================================
# DATABASE
# ==============================================================================
# For production, use PostgreSQL: postgresql://user:password@localhost/leaderboard_db
# For development, use SQLite: sqlite:///leaderboard.db
DATABASE_URL=sqlite:///leaderboard.db

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ==============================================================================
# LOGGING
# ==============================================================================
# Log directory - must be writable by the application
LEADERBOARD_LOG_DIR=logs

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LEADERBOARD_LOG_LEVEL=INFO

# ==============================================================================
# OLLAMA CONFIGURATION (Optional)
# ==============================================================================
# Use Ollama for advanced answer extraction (requires Ollama server running)
# Install from https://ollama.ai
USE_OLLAMA=False
MINDS_EYE_OPTION_EXTRACTOR_MODEL=gemma3:4b
MINDS_EYE_OLLAMA_BASE_URL=http://localhost:11434

# ==============================================================================
# GRADING - SINGLE SHARED JUDGE (GPT-4o via OpenAI API)
# ==============================================================================
# All three tasks are graded by the SAME model - GPT-4o - through the OpenAI
# chat-completions API, so scores are uniform and comparable across tasks.
# Only the grading METHOD differs by task (answer-extractor for do_you_see_me
# and minds_eye, LLM-as-judge for spatial).
#
# The ONLY value read here for grading is the API key. If it is left blank (or
# a call fails) the grader falls back to deterministic string/numeric matching
# and the leaderboard still works fully offline.
OPENAI_API_KEY=
# Per-call timeout (seconds) for grading requests
GRADING_TIMEOUT=60

# ==============================================================================
# FILE UPLOADS
# ==============================================================================
# Maximum file size (50MB)
MAX_CONTENT_LENGTH=52428800

# ==============================================================================
# DEPLOYMENT NOTES
# ==============================================================================
# Production Deployment with Gunicorn:
# 
# 1. Install: pip install gunicorn
# 
# 2. Run with multiple workers:
#    gunicorn --workers 4 \
#             --worker-class sync \
#             --bind 0.0.0.0:5050 \
#             --timeout 120 \
#             --access-logfile logs/access.log \
#             --error-logfile logs/error.log \
#             backend.web:app
# 
# 3. For systemd service, create /etc/systemd/system/leaderboard.service:
#    [Unit]
#    Description=Vision Leaderboard API
#    After=network.target
#
#    [Service]
#    Type=notify
#    User=www-data
#    WorkingDirectory=/opt/leaderboard
#    Environment="DATABASE_URL=postgresql://user:pass@localhost/leaderboard"
#    ExecStart=/opt/leaderboard/venv/bin/gunicorn --workers 4 backend.web:app
#    Restart=always
#    RestartSec=10
#
#    [Install]
#    WantedBy=multi-user.target
#
# ==============================================================================

