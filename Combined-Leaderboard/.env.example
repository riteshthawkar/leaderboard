# Combined Leaderboard configuration
# Copy to .env for local testing, then replace secrets before deployment.

# Runtime data
LEADERBOARD_DATA_DIR=.
RESULTS_DIR=
LEADERBOARD_STORE_FILE=
# TASKS_DIR=./tasks

# Flask
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5050
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=180
# Use local for localhost development. Public mode requires HTTPS origins and
# secure cookies and makes readiness fail closed when they are misconfigured.
DEPLOYMENT_MODE=local

# Security and auth
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex-string
# Local HTTP development only. Set true in production.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_NAME=ms_vista_session
SESSION_LIFETIME_DAYS=7
DISABLE_SUBMISSION_AUTH=false
TEST_SUBMISSION_USER=local-test@ms-vista.local
ADMIN_EMAILS=
AUTH_DEV_MODE=false
ALLOW_INSECURE_SECRET=false
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Set this to the exact number of trusted reverse proxies in production.
# Keep 0 when clients connect directly to the API process.
TRUST_PROXY_HOPS=0

# OAuth sign-in / sign-up
# Configure callback URLs as:
#   http://localhost:5050/api/auth/oauth/google/callback
#   http://localhost:5050/api/auth/oauth/microsoft/callback
OAUTH_REDIRECT_BASE_URL=http://localhost:5050
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Email delivery for verification and password reset
FRONTEND_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:5050
PRIVACY_POLICY_URL=
# The frontend and API are deployed separately. Keep both public origins
# explicit in production so auth links never depend on the request Host header.
# Production auth refuses to derive these URLs from the request Host header.
ACS_CONNECTION_STRING=
ACS_ENDPOINT=
ACS_SENDER_ADDRESS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=
EMAIL_SEND_TIMEOUT_SECONDS=30

# Rate limits
SUBMISSIONS_PER_HOUR=10
SUBMISSION_DAILY_LIMIT_PER_BENCHMARK=1
SUBMISSION_RESERVATION_TIMEOUT_MINUTES=15
LIMITER_STORAGE_URI=memory://
HEALTH_CACHE_SECONDS=15

# Database
# SQLite is the current local/private deployment database.
DATABASE_URL=sqlite:///leaderboard.db
AUTH_DATABASE_URL=
SUBMISSION_DATABASE_URL=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
SQLITE_BUSY_TIMEOUT_MS=5000

# Verified SQLite backups. In production these default to enabled and are
# stored under LEADERBOARD_DATA_DIR/backups.
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_DIR=
# Optional second mounted filesystem. Public mode always requires a configured
# mirror on a different device; REQUIRE_OFFSITE_BACKUP controls local mode only.
AUTO_BACKUP_MIRROR_DIR=
REQUIRE_OFFSITE_BACKUP=false
AUTO_BACKUP_INTERVAL_HOURS=48
AUTO_BACKUP_RETENTION_COUNT=15
AUTO_BACKUP_POLL_SECONDS=300
AUTO_BACKUP_RUN_ON_START=true
MIN_FREE_DISK_BYTES=1073741824
MIN_FREE_DISK_PERCENT=5

# Ground truth
GROUND_TRUTHS_DIR=./Ground_truths
GROUND_TRUTHS_SOURCE=auto
GROUND_TRUTHS_HF_REPO=
GROUND_TRUTHS_HF_REPO_TYPE=dataset
# Public deployments using the HF source require the full immutable 40-character commit SHA.
GROUND_TRUTHS_HF_REVISION=main
GROUND_TRUTHS_HF_CACHE_DIR=
GROUND_TRUTHS_HF_FORCE_REFRESH=false
HF_TOKEN=

# Official spatial launch guard
REQUIRE_OFFICIAL_SPATIAL=false
OFFICIAL_SPATIAL_MIN_SAMPLES=1000

# Benchmark source roots
DO_YOU_SEE_ME_ROOT=../Do-You-See-Me
MINDS_EYE_ROOT=../Mind-s-Eye

# Optional grading helpers
OPENAI_API_KEY=
GRADING_TIMEOUT=60
MINDS_EYE_OPTION_EXTRACTOR_MODEL=gemma3:4b
MINDS_EYE_OLLAMA_BASE_URL=http://localhost:11434

# Visual Cognition Index weights
VCI_W_PERCEPTION=0.5
VCI_W_COGNITION=0.5
VCI_W_REASONING=0.0

# Golden set generation
GOLDEN_SET_DIR=./golden_set
GOLDEN_SET_SIZE_PER_TASK=25
GOLDEN_SET_SEED=42

# Uploads and logging
MAX_CONTENT_LENGTH=52428800
MAX_AUTH_REQUEST_BYTES=16384
MAX_FILE_SIZE_PER_SUBMISSION=52428800
MAX_SUBMISSION_LINE_CHARS=100000
MAX_SPATIAL_ARCHIVE_BYTES=10485760
MAX_SPATIAL_MULTIPART_BYTES=12582912
MAX_SPATIAL_SUBMISSION_BYTES=20971520
MAX_SPATIAL_MANIFEST_BYTES=1048576
MAX_SPATIAL_REPORT_BYTES=2097152
MAX_SPATIAL_ZIP_COMPRESSION_RATIO=100
LEADERBOARD_LOG_DIR=logs
LEADERBOARD_LOG_LEVEL=INFO
